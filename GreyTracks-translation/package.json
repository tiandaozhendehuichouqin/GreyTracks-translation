{
  "name": "browser-translator",
  "version": "1.0.0",
  "description": "跨浏览器划词翻译插件 - 支持 Chrome 和 Firefox",
  "main": "src/background/background.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js chrome",
    "build:firefox": "node scripts/build.js firefox",
    "package": "node scripts/package.js",
    "package:chrome": "node scripts/package.js chrome",
    "package:firefox": "node scripts/package.js firefox",
    "verify": "node scripts/verify.js",
    "watch": "node scripts/watch.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,json}\""
  },
  "keywords": [
    "browser-extension",
    "translation",
    "chrome",
    "firefox",
    "webextension"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
