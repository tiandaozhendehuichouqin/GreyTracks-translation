{
  "manifest_version": 2,
  "name": "GreyTracks",
  "version": "1.0.0",
  "description": "GreyTracks 跨浏览器划词翻译插件，支持 Chrome 和 Firefox",
  "default_locale": "zh_CN",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.svg",
      "32": "icons/icon32.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_title": "GreyTracks"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.svg",
    "32": "icons/icon32.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "web_accessible_resources": [
    "styles/*.css",
    "icons/*.svg"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "translator@greytracks.com",
      "strict_min_version": "78.0"
    }
  }
}
